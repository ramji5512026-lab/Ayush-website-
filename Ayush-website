<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ayush ka website | Secure Server</title>
    <style>
        /* CSS Variables for Hacker Theme */
        :root {
            --matrix-green: #00ff41;
            --dark-bg: #030a03;
            --black-bg: #000000;
        }

        /* General Styles */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth; /* Smooth scrolling for navigation */
        }

        body {
            font-family: 'Consolas', 'Courier New', Courier, monospace;
            background-color: var(--dark-bg);
            color: var(--matrix-green);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }
        ::-webkit-scrollbar-track {
            background: var(--black-bg);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--matrix-green);
        }

        /* Navigation Bar */
        header {
            background-color: var(--black-bg);
            padding: 1rem 5%;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid var(--matrix-green);
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 0 15px rgba(0, 255, 65, 0.2);
        }

        header h1 {
            font-size: 1.8rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            text-shadow: 0 0 5px var(--matrix-green);
            color: #ffffff;
        }

        nav a {
            color: var(--matrix-green);
            text-decoration: none;
            margin-left: 20px;
            font-size: 1.1rem;
            font-weight: bold;
            transition: 0.3s;
        }

        nav a:hover {
            color: #ffffff;
            text-shadow: 0 0 8px var(--matrix-green);
        }

        /* Section Layout */
        section {
            min-height: 100vh;
            padding: 100px 5% 50px 5%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
            background: #020502;
            border: 1px solid var(--matrix-green);
            border-radius: 5px;
            padding: 30px;
            box-shadow: inset 0 0 20px rgba(0, 255, 65, 0.05);
        }

        h2.section-title {
            color: #ffffff;
            font-size: 2.2rem;
            border-bottom: 1px dashed var(--matrix-green);
            padding-bottom: 10px;
            margin-bottom: 20px;
            display: inline-block;
        }

        p {
            font-size: 1.1rem;
            margin-bottom: 15px;
        }

        .terminal-prompt {
            color: #ffffff;
            font-weight: bold;
        }

        /* Blinking Cursor */
        .cursor {
            display: inline-block;
            width: 10px;
            height: 1.2rem;
            background-color: var(--matrix-green);
            animation: blink 1s step-end infinite;
            vertical-align: middle;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        /* Skills/Hobby Box */
        .cyber-box {
            background-color: var(--black-bg);
            padding: 20px;
            margin-top: 20px;
            border-left: 4px solid var(--matrix-green);
        }

        .cyber-box ul {
            list-style-type: square;
            margin-left: 20px;
            margin-top: 10px;
        }

        /* Buttons */
        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 25px;
            background-color: transparent;
            color: var(--matrix-green);
            text-decoration: none;
            border: 1px solid var(--matrix-green);
            font-size: 1.1rem;
            font-weight: bold;
            transition: 0.3s;
            text-transform: uppercase;
            cursor: pointer;
        }

        .btn:hover {
            background-color: var(--matrix-green);
            color: var(--black-bg);
            box-shadow: 0 0 15px var(--matrix-green);
        }

        /* Contact Form */
        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .contact-form input, .contact-form textarea {
            background-color: var(--black-bg);
            border: 1px solid var(--matrix-green);
            color: var(--matrix-green);
            padding: 10px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 1rem;
            outline: none;
        }

        .contact-form input:focus, .contact-form textarea:focus {
            box-shadow: 0 0 10px rgba(0, 255, 65, 0.3);
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 20px;
            background-color: var(--black-bg);
            border-top: 1px solid var(--matrix-green);
        }

        /* Mobile View Adjustments */
        @media (max-width: 768px) {
            header {
                flex-direction: column;
                gap: 10px;
            }
            nav a {
                margin: 0 10px;
                font-size: 0.9rem;
            }
            section {
                padding-top: 120px;
            }
        }
    </style>
</head>
<body>

    <!-- Header & Navigation -->
    <header>
        <h1>Ayush_Server</h1>
        <nav>
            <a href="#home">~/home</a>
            <a href="#about">~/about</a>
            <a href="#skills">~/skills</a>
            <a href="#contact">~/contact</a>
        </nav>
    </header>

    <!-- HOME SECTION -->
    <section id="home">
        <div class="container">
            <h2 class="section-title">Terminal_Access</h2>
            <div id="typewriter-text" style="white-space: pre-wrap; font-size: 1.2rem;"></div><span class="cursor"></span>
            <br><br>
            <a href="#about" class="btn">Initialize_Profile.sh</a>
        </div>
    </section>

    <!-- ABOUT SECTION -->
    <section id="about">
        <div class="container">
            <h2 class="section-title">Whoami</h2>
            <p><span class="terminal-prompt">root@ayush:~$</span> Fetching user profile...</p>
            <p><span class="terminal-prompt">></span> Name: Ayush</p>
            <p><span class="terminal-prompt">></span> Status: Active</p>
            <p><span class="terminal-prompt">></span> Bio: I am a tech enthusiast with a deep passion for exploring how systems work behind the scenes. Welcome to my personal server where I document my digital journey.</p>
        </div>
    </section>

    <!-- SKILLS & CYBERSECURITY SECTION -->
    <section id="skills">
        <div class="container">
            <h2 class="section-title">Cybersecurity_Protocol</h2>
            <p><span class="terminal-prompt">root@ayush:~$</span> cat skills.txt</p>
            
            <div class="cyber-box">
                <h3 style="color: #fff;">[ Ethical Hacking & Security ]</h3>
                <p style="margin-top: 10px;"><strong style="color: red;">DISCLAIMER:</strong> All security concepts, tools, and techniques practiced here are strictly for <em>educational purposes only</em>. My objective is to build stronger defenses by understanding vulnerabilities.</p>
                
                <p style="margin-top: 15px; color: #fff;">Areas of Interest:</p>
                <ul>
                    <li>Network Security & Packet Analysis</li>
                    <li>Vulnerability Assessment</li>
                    <li>Linux Administration & Command Line</li>
                    <li>Web Application Security</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- CONTACT SECTION -->
    <section id="contact">
        <div class="container">
            <h2 class="section-title">Establish_Connection</h2>
            <p><span class="terminal-prompt">root@ayush:~$</span> Send encrypted message to admin...</p>
            
            <form class="contact-form" onsubmit="sendMessage(event)">
                <input type="text" id="name" placeholder="Enter_Your_Name" required>
                <input type="email" id="email" placeholder="Enter_Your_IP/Email" required>
                <textarea id="message" rows="5" placeholder="Enter_Encrypted_Message..." required></textarea>
                <button type="submit" class="btn">Execute: Send_Message.exe</button>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 Ayush. Secure Connection Established. End of File.</p>
    </footer>

    <!-- JavaScript for Typing Animation & Form -->
    <script>
        // Typing Animation for Home Section
        const textArray =[
            "root@ayush-server:~$ Establishing secure connection...",
            "root@ayush-server:~$ Bypassing firewalls... Done.",
            "root@ayush-server:~$ Welcome to Ayush's Digital Space."
        ];
        let textIndex = 0;
        let charIndex = 0;
        const typeWriterElement = document.getElementById("typewriter-text");

        function typeWriter() {
            if (textIndex < textArray.length) {
                if (charIndex < textArray[textIndex].length) {
                    typeWriterElement.innerHTML += textArray[textIndex].charAt(charIndex);
                    charIndex++;
                    setTimeout(typeWriter, 50); // Typing speed
                } else {
                    typeWriterElement.innerHTML += "<br>";
                    textIndex++;
                    charIndex = 0;
                    setTimeout(typeWriter, 500); // Delay between lines
                }
            }
        }
        
        // Start typing effect when page loads
        window.onload = typeWriter;

        // Contact Form Fake Submit Alert
        function sendMessage(event) {
            event.preventDefault(); // Prevents page reload
            alert("SYSTEM MESSAGE: Secure payload (message) delivered to Ayush successfully!");
            document.querySelector('.contact-form').reset();
        }
    </script>
</body>
</html>
